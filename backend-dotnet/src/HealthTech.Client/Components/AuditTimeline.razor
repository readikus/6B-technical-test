@if (Entries.Count == 0)
{
    <p class="text-muted">No audit entries yet.</p>
}
else
{
    <div class="timeline mt-4">
        @foreach (var entry in Entries)
        {
            <div class="timeline-item">
                <div class="flex justify-between">
                    <span class="timeline-action">@entry.Action</span>
                    <span class="timeline-date">@entry.CreatedAt.ToString("g")</span>
                </div>
                @if (entry.Changes is not null && entry.Changes.Count > 0)
                {
                    <div class="timeline-changes">
                        @foreach (var change in entry.Changes)
                        {
                            <div class="text-sm">
                                <strong>@change.Key</strong>: @FormatChange(change.Value)
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public List<AuditLogResponse> Entries { get; set; } = new();

    private static string FormatChange(object? value)
    {
        if (value is null) return "\u2014";
        return value.ToString() ?? "\u2014";
    }
}
